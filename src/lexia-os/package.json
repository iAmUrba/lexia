{
  "name": "lexia-os",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "packages/adapters/*",
    "apps/*"
  ],
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "verify:sprint1": "tsx packages/server/verify_sprint1.ts",
    "verify:sprint2": "tsx packages/server/verify_sprint2.ts",
    "verify:sprint3": "tsx packages/server/verify_sprint3.ts",
    "verify:sprint4": "tsx packages/server/verify_sprint4.ts",
    "verify:sprint5": "tsx packages/server/verify_sprint5.ts",
    "verify:graphclient": "tsx packages/server/verify_graphclient.ts",
    "verify:graphfilesystem": "tsx packages/server/verify_graphfilesystem.ts",
    "verify:e2e-read": "tsx packages/server/verify_e2e_read.ts",
    "verify:e2e-resilience": "tsx packages/server/verify_e2e_resilience.ts",
    "verify:executionplan": "tsx packages/server/verify_executionplan.ts",
    "verify:preflight": "tsx packages/server/verify_preflight.ts",
    "verify:dryrun": "tsx packages/server/verify_dryrun.ts",
    "verify:excelwriter": "tsx packages/server/verify_excelwriter.ts",
    "verify:pdfmover": "tsx packages/server/verify_pdfmover.ts",
    "verify:transactionmanager": "tsx packages/server/verify_transactionmanager.ts",
    "verify:recovery": "tsx packages/server/verify_recovery.ts",
    "verify:sqlite": "tsx packages/server/verify_sqlite.ts",
    "verify:graph-e2e": "tsx --env-file=.env packages/infrastructure/graph/run_real_graph.ts",
    "verify:graph-matrix": "tsx packages/infrastructure/graph/audit_matrix.ts",
    "vertical-slice": "tsx packages/server/run_vertical_slice.ts",
    "verify:all": "npm run verify:sprint1 && npm run verify:sprint2 && npm run verify:sprint3 && npm run verify:sprint4 && npm run verify:sprint5 && npm run verify:graphclient && npm run verify:executionplan && npm run verify:preflight && npm run verify:dryrun && npm run verify:excelwriter && npm run verify:pdfmover && npm run verify:transactionmanager && npm run verify:recovery",
    "test:sprint1": "tsx packages/server/test_sprint1.ts",
    "test:sprint2": "tsx packages/server/test_sprint2.ts",
    "test": "echo \"Error: no test specified\" && exit 1",
    "test:metrics": "tsx --test packages/application/usecases/ProcessCaseUseCase.regression.test.ts",
    "dev": "concurrently \"npm run dev -w packages/web\" \"npx tsx watch packages/server/server.ts\"",
    "start": "concurrently \"npm run start -w packages/web\" \"npx tsx packages/server/server.ts\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@azure/msal-node": "^5.4.1",
    "@electric-sql/pglite": "^0.5.4",
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^10.1.0",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "better-sqlite3": "^12.11.1",
    "cors": "^2.8.6",
    "drizzle-orm": "^0.45.2",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "fastify": "^5.10.0",
    "isomorphic-fetch": "^3.0.0",
    "pdf-parse": "^1.1.1",
    "playwright": "^1.61.1",
    "tesseract.js": "^7.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/supertest": "^7.2.0",
    "concurrently": "^10.0.3",
    "drizzle-kit": "^0.31.10",
    "supertest": "^7.2.2"
  }
}
